{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "data.json"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/go/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/go-final/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
